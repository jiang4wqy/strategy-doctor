# Strategy Doctor server
DOCTOR_HOST=0.0.0.0
DOCTOR_PORT=8080
DOCTOR_WEB_ACCESS_CODE=replace-with-reviewer-access-code
DOCTOR_SESSION_SECRET=replace-with-random-32-plus-character-secret
DOCTOR_API_KEYS=replace-with-private-agent-key

# Optional server tuning
DOCTOR_SESSION_TTL_SECONDS=43200
DOCTOR_BODY_LIMIT=32768
DOCTOR_STATIC_ROOT=web/dist

# Client-side scripts
STRATEGY_DOCTOR_URL=http://127.0.0.1:8080
STRATEGY_DOCTOR_API_KEY=replace-with-private-agent-key
STRATEGY_DOCTOR_TUNNEL_PORT=18080

# Optional remote preview helper
STRATEGY_DOCTOR_SSH_HOST=replace-with-server-ip-or-domain
STRATEGY_DOCTOR_SSH_PORT=replace-with-ssh-port
STRATEGY_DOCTOR_SSH_USER=replace-with-ssh-user
