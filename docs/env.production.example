# Copy this file to .env.production and set strong values before deployment.

DOCTOR_HOST=0.0.0.0
DOCTOR_PORT=8080
DOCTOR_WEB_ACCESS_CODE=replace-with-strong-access-code
DOCTOR_SESSION_SECRET=replace-with-at-least-32-char-secret
DOCTOR_API_KEYS=agent-key-1,agent-key-2
DOCTOR_SESSION_TTL_SECONDS=43200
DOCTOR_AUTH_RATE_LIMIT_DISABLED=0
DOCTOR_AUTH_RATE_LIMIT_MAX=5
DOCTOR_AUTH_RATE_LIMIT_WINDOW=15 minutes
DOCTOR_STATIC_ROOT=web/dist
